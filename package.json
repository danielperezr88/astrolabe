{
  "name": "astrolabe",
  "version": "0.1.0",
  "description": "Codebase knowledge graph engine — multi-language static analysis with graph persistence, community detection, and hybrid search",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/core",
    "packages/cli",
    "packages/vscode"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspace packages/core --if-present",
    "lint": "npm run lint --workspace packages/core --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "keywords": [
    "code-analysis",
    "knowledge-graph",
    "static-analysis",
    "dependency-graph",
    "tree-sitter"
  ],
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
