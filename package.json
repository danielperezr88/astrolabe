{
  "name": "astrolabe",
  "version": "0.1.0",
  "description": "Codebase knowledge graph engine — multi-language static analysis with graph persistence, community detection, and hybrid search",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "astrolabe": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "keywords": [
    "code-analysis",
    "knowledge-graph",
    "static-analysis",
    "dependency-graph",
    "tree-sitter"
  ],
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "graphology": "^0.25.4",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
