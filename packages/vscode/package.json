{
  "name": "astrolabe-vscode",
  "version": "1.0.0",
  "description": "VSCode extension for Astrolabe — interactive codebase knowledge graph exploration",
  "icon": "icon.png",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:astrolabe.analyze",
    "onCommand:astrolabe.showGraph",
    "onCommand:astrolabe.query",
    "onCommand:astrolabe.context",
    "onCommand:astrolabe.impact"
  ],
  "main": "dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "astrolabe.analyze",
        "title": "Astrolabe: Analyze Codebase"
      },
      {
        "command": "astrolabe.showGraph",
        "title": "Astrolabe: Show Knowledge Graph"
      },
      {
        "command": "astrolabe.query",
        "title": "Astrolabe: Query Knowledge Graph"
      },
      {
        "command": "astrolabe.context",
        "title": "Astrolabe: Show Symbol Context"
      },
      {
        "command": "astrolabe.impact",
        "title": "Astrolabe: Analyze Impact"
      }
    ]
  },
  "scripts": {
    "build": "node -e \"if(!require('fs').existsSync('webview/node_modules'))process.exit(1)\" || npm --prefix webview install && tsc && npm run build:webview",
    "build:webview": "npm --prefix webview run build",
    "watch": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "license": "MIT",
  "dependencies": {
    "@astrolabe/core": "^1.0.0",
    "@astrolabe/shared": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.7.0"
  }
}
