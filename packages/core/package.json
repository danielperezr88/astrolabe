{
  "name": "@astrolabe-dev/core",
  "version": "1.0.0",
  "description": "Codebase knowledge graph engine — multi-language static analysis with graph persistence",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "wasm",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "license": "MIT",
  "keywords": [
    "code-analysis",
    "knowledge-graph",
    "static-analysis",
    "dependency-graph",
    "tree-sitter"
  ],
  "dependencies": {
    "@astrolabe-dev/shared": "^1.0.0",
    "@ladybugdb/core": "^0.16.1",
    "better-sqlite3": "^11.0.0",
    "web-tree-sitter": "^0.26.8"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^2.0.0"
  }
}
