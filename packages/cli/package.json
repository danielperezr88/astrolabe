{
  "name": "@astrolabe/cli",
  "version": "0.1.0",
  "description": "Astrolabe CLI — command-line interface for codebase knowledge graph analysis",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "astrolabe": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "license": "MIT",
  "keywords": [
    "astrolabe",
    "code-analysis",
    "knowledge-graph",
    "cli"
  ],
  "dependencies": {
    "@astrolabe/core": "^0.1.0",
    "@astrolabe/shared": "^0.1.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
