{
  "name": "@astrolabe-dev/shared",
  "version": "1.0.8",
  "description": "Shared type definitions for Astrolabe packages",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
