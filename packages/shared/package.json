{
  "name": "@astrolabe/shared",
  "version": "0.1.0",
  "description": "Shared type definitions for Astrolabe packages",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
