# Astrolabe Environment Variables
# Copy this file to .env and fill in the values you need.

# ── Authentication ──────────────────────────────────────────────────────────

# API key for HTTP server bearer token auth.
# If set, all API requests require an Authorization: Bearer <key> header.
# ASTROLABE_API_KEY=

# OpenAI API key — used for RAG chat and wiki generation when ASTROLABE_API_KEY is not set.
# OPENAI_API_KEY=

# ── LLM Configuration ──────────────────────────────────────────────────────

# Custom LLM base URL (default: https://api.openai.com/v1).
# Set this for Azure OpenAI, local LLMs, or other OpenAI-compatible endpoints.
# ASTROLABE_LLM_BASE_URL=

# LLM model name for RAG chat (default: gpt-4o-mini).
# ASTROLABE_MODEL=

# ── Embeddings ──────────────────────────────────────────────────────────────

# Embedding model name (default: Xenova/all-MiniLM-L6-v2 for local).
# For remote embeddings, set ASTROLABE_EMBEDDING_URL as well.
# ASTROLABE_EMBEDDING_MODEL=

# Embedding API URL — enables remote embedding provider when set.
# Leave empty for local WASM-based embeddings (no API key needed).
# ASTROLABE_EMBEDDING_URL=

# API key for remote embedding provider.
# Only needed when using a remote embedding service.
# ASTROLABE_EMBEDDING_API_KEY=

# Embedding vector dimensions (default: 384 for local, provider-specific for remote).
# Override only if using a non-default model.
# ASTROLABE_EMBEDDING_DIMS=

# ── HTTP Server ─────────────────────────────────────────────────────────────

# Rate limit: max requests per minute per IP (default: 100).
# Set to 0 to disable rate limiting (not recommended for production).
# ASTROLABE_RATE_LIMIT=

# ── Analysis ────────────────────────────────────────────────────────────────

# Maximum file size in bytes for analysis (default: 1MB = 1048576).
# Files larger than this are skipped during scanning.
# ASTROLABE_MAX_FILE_SIZE=

# Worker thread threshold — minimum files to trigger parallel parsing (default: 50).
# Below this threshold, parsing runs on the main thread.
# ASTROLABE_WORKER_THRESHOLD=

# ── Debugging ───────────────────────────────────────────────────────────────

# Enable debug/verbose logging for pipelines and persistence.
# ASTROLABE_DEBUG=

# ── CI/Test Only ────────────────────────────────────────────────────────────

# Enable integration tests (used by CI pipeline, not for production).
# ASTROLABE_INTEGRATION=
